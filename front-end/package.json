{
  "name": "pragathi-enterprises",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "git add . && git commit -m \"deploy\" && git push"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.4",
  "dependencies": {
    "@angular/animations": "21.1.4",
    "@angular/common": "21.1.4",
    "@angular/compiler": "21.1.4",
    "@angular/core": "21.1.4",
    "@angular/forms": "21.1.4",
    "@angular/platform-browser": "21.1.4",
    "@angular/router": "21.1.4",
    "@types/crypto-js": "^4.2.2",
    "crypto-js": "^4.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "ngx-spinner": "^21.0.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.18",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "21.1.4",
    "@angular/cli": "21.1.4",
    "@angular/compiler-cli": "21.1.4",
    "@types/html2canvas": "^0.5.35",
    "@types/xlsx": "^0.0.35",
    "jsdom": "^27.1.0",
    "ts-prune": "^0.10.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}